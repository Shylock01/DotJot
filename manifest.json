{
  "manifest_version": 3,
  "name": "DotJot",
  "version": "0.1.3",
  "description": "A simple note taking app utilizing the dot grid layout.",
  "permissions": [
    "storage"
  ],
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/Shylock01/DotJot/main/Graphics/favicon_padded.png",
      "sizes": "128x128",
      "type": "image/png"
    }
  ],
  "action": {
    "default_title": "Open DotJot",
    "default_icon": {
      "128": "Graphics/favicon_padded.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
